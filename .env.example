# HTTP listen port for the web UI / API
PORT=8080

# Bind address (0.0.0.0 to expose, 127.0.0.1 for localhost-only)
BIND_ADDR=127.0.0.1

# Cookie signing key — REQUIRED. Must be at least 64 bytes of random data.
# Generate with: openssl rand -hex 64
SESSION_KEY=replace_me_with_64_bytes_of_hex_or_base64_random

# Where JSON state files live (users.json, connections.json, schedules.json)
DATA_DIR=./data

# Where mongodump archives are written
BACKUP_DIR=./backups

# Logging
RUST_LOG=info,mongodb_utils=debug
